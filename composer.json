{
    "name": "bouke/portfolio",
    "require": {
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpmailer/phpmailer": "^6.9",
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "Portfolio\\Controllers\\": "Controllers/",
            "Portfolio\\Core\\": "Core/",
            "Portfolio\\Entities\\": "Entities/",
            "Portfolio\\Models\\": "Models/",
